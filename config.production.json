{
  "server": {
    "port": 8080,
    "readTimeoutMs": 5000,
    "writeTimeoutMs": 10000,
    "idleTimeoutMs": 60000,
    "maxBodyBytes": 1048576,
    "allowedOrigins": []
  },
  "security": {
    "requireApiKey": true,
    "apiKey": ""
  },
  "router": {
    "bufferSize": 5000,
    "workerCount": 10,
    "maxRetries": 5,
    "retryDelayMs": 200
  },
  "channels": {
    "email": {
      "enabled": true
    },
    "sms": {
      "enabled": true
    },
    "inapp": {
      "enabled": true
    },
    "social_media": {
      "enabled": true
    }
  },
  "metrics": {
    "maxFailureRate": 0.1,
    "maxQueueUtilization": 0.75,
    "maxProcessingTime": 3000
  },
  "distribution": {
    "deduplicationTTL": 60
  },
  "environment": "production"
}

{
  "server": {
    "port": 8080
  },
  "router": {
    "bufferSize": 5000,
    "workerCount": 10,
    "maxRetries": 5,
    "retryDelayMs": 200
  },
  "channels": {
    "email": {
      "enabled": true
    },
    "sms": {
      "enabled": true
    },
    "inapp": {
      "enabled": true
    },
    "social_media": {
      "enabled": true
    }
  },
  "metrics": {
    "maxFailureRate": 0.1,
    "maxQueueUtilization": 0.75,
    "maxProcessingTime": 3000
  },
  "distribution": {
    "deduplicationTTL": 60
  },
  "environment": "production"
}
